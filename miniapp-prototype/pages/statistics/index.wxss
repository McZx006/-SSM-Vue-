.section-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.filter-card {
  display: flex;
  gap: 18rpx;
}

.picker-chip {
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  color: #0f766e;
  background: #ecfdf5;
  font-weight: 700;
}

.chart-placeholder {
  height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  color: #94a3b8;
  background: #f8fafc;
}

.rank-row {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.rank-name {
  margin-bottom: 6rpx;
  font-weight: 800;
}

.trend-row {
  margin-bottom: 22rpx;
}

.trend-month {
  margin-bottom: 8rpx;
  font-weight: 800;
}

.bar-track {
  overflow: hidden;
  height: 28rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
}

.bar {
  height: 14rpx;
  max-width: 100%;
}

.income-bar {
  background: #16a34a;
}

.expense-bar {
  background: #ea580c;
}

.trend-value {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.expense-text {
  color: #ea580c;
  font-weight: 800;
}

.advice {
  color: #64748b;
  line-height: 1.7;
}

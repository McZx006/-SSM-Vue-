<view class="page">
  <view class="card filter-card">
    <picker mode="date" fields="month" value="{{month}}" bindchange="changeMonth">
      <view class="picker-chip">分类月份：{{month}}</view>
    </picker>
    <picker mode="date" fields="year" value="{{year}}" bindchange="changeYear">
      <view class="picker-chip">趋势年份：{{year}}</view>
    </picker>
  </view>

  <view class="card">
    <view class="section-title">月度趋势</view>
    <view wx:if="{{loading}}" class="chart-placeholder">正在加载...</view>
    <view wx:elif="{{!monthly.length}}" class="chart-placeholder">暂无趋势数据</view>
    <view wx:else class="trend-list">
      <view class="trend-row" wx:for="{{monthly}}" wx:key="month">
        <view class="trend-month">{{item.month}}月</view>
        <view class="bar-track">
          <view class="bar income-bar" style="width: {{item.income / 100}}%;"></view>
          <view class="bar expense-bar" style="width: {{item.expense / 100}}%;"></view>
        </view>
        <view class="trend-value">收 {{item.income}} / 支 {{item.expense}}</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">分类占比</view>
    <view wx:if="{{!categories.length}}" class="chart-placeholder">暂无分类数据</view>
    <view wx:else class="rank-row" wx:for="{{categories}}" wx:key="name">
      <view>
        <view class="rank-name">{{item.name}}</view>
        <view class="muted">占比 {{item.percent}}%</view>
      </view>
      <view class="expense-text">¥{{item.amount}}</view>
    </view>
  </view>

  <view class="card advice-card">
    <view class="section-title">智能建议</view>
    <view class="advice">{{advice}}</view>
  </view>
</view>

.form-card {
  margin-bottom: 24rpx;
  padding: 34rpx;
  border-radius: 34rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.08);
}

.form-title {
  font-size: 40rpx;
  font-weight: 900;
}

.form-tip,
.tip-text {
  margin: 12rpx 0 24rpx;
  color: #64748b;
  font-size: 25rpx;
  line-height: 1.7;
}

.type-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.type-pill {
  padding: 22rpx 0;
  border-radius: 22rpx;
  text-align: center;
  color: #64748b;
  background: #f8fafc;
  font-weight: 800;
}

.type-pill.active {
  color: #ffffff;
  background: #ea580c;
}

.type-pill.income.active {
  background: #16a34a;
}

.input {
  height: 92rpx;
  margin-bottom: 20rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.picker-field {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  color: #0f172a;
  background: #f8fafc;
}

.picker-arrow {
  color: #94a3b8;
  font-size: 42rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 900;
}

.hero-card {
  margin-bottom: 24rpx;
  padding: 34rpx;
  border-radius: 34rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0f766e, #14b8a6 52%, #f97316);
  box-shadow: 0 24rpx 48rpx rgba(15, 118, 110, 0.22);
}

.hero-title {
  margin-top: 10rpx;
  font-size: 44rpx;
  font-weight: 800;
}

.hero-text {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
}

.hero-progress {
  height: 18rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.28);
  overflow: hidden;
}

.hero-progress-inner {
  height: 100%;
  border-radius: 999rpx;
  background: #ffffff;
}

.quick-grid,
.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.quick-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
  margin-bottom: 24rpx;
}

.quick-item {
  padding: 24rpx 0;
  border-radius: 24rpx;
  text-align: center;
  background: #ffffff;
  color: #0f766e;
  font-weight: 700;
}

.quick-item.income {
  color: #16a34a;
}

.income-text {
  color: #16a34a;
}

.expense-text {
  color: #ea580c;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
}

.advice {
  margin-top: 12rpx;
  color: #64748b;
  line-height: 1.7;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.filter {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #64748b;
  font-size: 26rpx;
}

.filter.active {
  color: #0f766e;
  background: #ecfdf5;
  font-weight: 700;
}

.bill-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: #ffffff;
}

.summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #ffffff, #ecfdf5);
}

.summary-columns {
  display: flex;
  gap: 20rpx;
  text-align: right;
}

.summary-text {
  margin-top: 6rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.summary-action {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: #0f766e;
  font-size: 24rpx;
}

.empty-card {
  padding: 60rpx 30rpx;
  border-radius: 28rpx;
  text-align: center;
  color: #94a3b8;
  background: #ffffff;
}

.bill-title {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.income-text {
  color: #16a34a;
  font-weight: 800;
}

.expense-text {
  color: #ea580c;
  font-weight: 800;
}

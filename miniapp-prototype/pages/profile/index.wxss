.profile-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
  padding: 34rpx;
  border-radius: 34rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0f766e, #14b8a6);
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.24);
  font-size: 42rpx;
  font-weight: 800;
}

.username {
  font-size: 36rpx;
  font-weight: 800;
}

.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #eef2f7;
  font-weight: 700;
}

.menu-row:last-child {
  border-bottom: none;
}

.menu-title {
  margin-bottom: 6rpx;
}

.menu-arrow {
  color: #94a3b8;
  font-size: 42rpx;
}

.logout-button {
  margin-top: 30rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  text-align: center;
  color: #dc2626;
  background: #ffffff;
  font-weight: 800;
}

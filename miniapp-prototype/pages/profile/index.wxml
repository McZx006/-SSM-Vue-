<view class="page">
  <view class="profile-card">
    <view class="avatar">{{avatarText}}</view>
    <view>
      <view class="username">{{userInfo && userInfo.username ? userInfo.username : 'testuser'}}</view>
      <view class="muted">月度预算 ¥{{budget}}</view>
    </view>
  </view>

  <view class="card menu-card">
    <view class="menu-row" wx:for="{{menuItems}}" wx:key="title">
      <view>
        <view class="menu-title">{{item.title}}</view>
        <view class="muted">{{item.desc}}</view>
      </view>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <view class="logout-button" bindtap="logout">退出登录</view>
</view>

page {
  min-height: 100vh;
  background: #f6f8fb;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

.page {
  padding: 28rpx;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.06);
}

.muted {
  color: #64748b;
  font-size: 24rpx;
}

.amount {
  font-size: 44rpx;
  font-weight: 800;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0f766e, #f97316);
  font-weight: 700;
}
